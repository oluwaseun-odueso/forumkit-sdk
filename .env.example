# ── Database ──────────────────────────────────────────────────────
# Direct connection — migrations only (port 5432)
DATABASE_URL=postgresql://postgres:password@localhost:5432/forumkit

# Pooled connection — application runtime (port 6543 on Supabase)
DATABASE_POOL_URL=postgresql://postgres:password@localhost:5432/forumkit

# ── Auth ──────────────────────────────────────────────────────────
# Shared secret used to verify JWTs signed by the host application
FORUM_SECRET_KEY=change-this-to-a-long-random-string

# ── AI providers (all optional — local fallbacks used if absent) ──
AI_PROVIDER=local              # local | openai | anthropic
OPENAI_API_KEY=
ANTHROPIC_API_KEY=

MODERATION_PROVIDER=local      # local | perspective
PERSPECTIVE_API_KEY=

EMBEDDING_PROVIDER=local       # local | openai
# Must match the provider: 384 for local all-MiniLM, 1536 for OpenAI
# Set this BEFORE running migrations — do not change on an existing database
EMBEDDING_DIMENSION=384

# ── App ───────────────────────────────────────────────────────────
PORT=3000
LOG_LEVEL=info                 # error | warn | info | debug
NODE_ENV=development           # development | production
SESSION_TTL_MINUTES=15
MAX_POST_LENGTH=10000
